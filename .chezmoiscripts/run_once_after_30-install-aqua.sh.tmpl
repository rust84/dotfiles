{{ if (eq .chezmoi.os "linux") -}}
#!{{ lookPath "bash" }}

set -euo pipefail

# Define colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Function to print a message with a color
print_msg() {
	local msg=$1
	local color=$2
	echo -e "${color}${msg}${NC}"
}

print_msg "Aqua ========================================================" $YELLOW

# renovate: depName=aquaproj/aqua datasource=github-releases
current_aqua_version=v2.57.1
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export AQUA_ROOT_DIR="${AQUA_ROOT_DIR:-$XDG_DATA_HOME/aquaproj-aqua}"
export AQUA_CONFIG="${AQUA_CONFIG:-$XDG_CONFIG_HOME/aqua/aqua.yaml}"
export AQUA_GLOBAL_CONFIG="${AQUA_GLOBAL_CONFIG:-$AQUA_CONFIG}"
export PATH="$AQUA_ROOT_DIR/bin:$PATH"

if ! command -v aqua >/dev/null 2>&1 || [ "$(aqua -v | head -n1 | cut -d" " -f3 | sed "s/^/v/")" != "$current_aqua_version" ]; then
  print_msg "Aqua installing..." $GREEN
  curl -sSfL https://raw.githubusercontent.com/aquaproj/aqua-installer/v4.0.4/aqua-installer | bash -s -- -v $current_aqua_version
fi

# This script will run whenever I added something to .config/aqua.yaml
# .config/aqua.yaml hash: {{ include "private_dot_config/aqua/aqua.yaml.tmpl" | sha256sum }}
print_msg "Aqua is updating packages..." $GREEN
aqua install -a

{{ end -}}
