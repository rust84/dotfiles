#!{{ lookPath "bash" }}

set -euo pipefail

# Define colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Function to print a message with a color
print_msg() {
	local msg=$1
	local color=$2
	echo -e "${color}${msg}${NC}"
}

print_msg "Package installs ========================================================" $YELLOW
# Setup fedora cli utils
{{ if (eq .os "fedora") -}}
  print_msg "Detected Fedora, triggering update" $GREEN
  PACKAGE_FILE="{{ joinPath .chezmoi.sourceDir "private_dot_config" "dot_chezmoi_packages" "fedora.txt" }}"
  sudo dnf upgrade
{{- end }}

# Setup android cli utils
{{ if (eq .os "android") -}}
  print_msg "Detected Android, triggering update" $GREEN
  PACKAGE_FILE="{{ joinPath .chezmoi.sourceDir "private_dot_config" "dot_chezmoi_packages" "android.txt" }}"
  sudo dnf upgrade
{{- end }}

if [ -z "$PACKAGE_FILE" ]; then
  print_msg "No valid OS detected, could not determine what packages to install.  Exiting..." $RED
  exit 1
fi

if [ ! -f "$PACKAGE_FILE" ]; then
  print_msg "Package file not found at $PACKAGE_FILE. Exiting..." $RED
  exit 1
fi

# Print a message to indicate that the script is starting
print_msg "Starting package installation... $PACKAGE_FILE" $GREEN

packages=()

# Loop over each package name and build a package array
while IFS= read -r package || [ -n "$package" ]; do
  package="${package#"${package%%[![:space:]]*}"}"
  package="${package%"${package##*[![:space:]]}"}"

  if [ -z "$package" ] || [[ "$package" == \#* ]]; then
    continue
  fi

  packages+=("$package")
done < "$PACKAGE_FILE"


if [[ ${#packages[@]} -gt 0 ]]; then
  print_msg "Installing packages: ${packages[*]}..." $YELLOW

{{ if (eq .os "fedora") -}}
  # Install all packages using dnf
  sudo dnf install -y --skip-unavailable "${packages[@]}"
{{- end }}

{{ if (eq .os "ubuntu") -}}
  # Install all packages using apt
  sudo apt install -y "${packages[@]}"
{{- end }}
fi

# Print a message to indicate that the script is finished
print_msg "Package installation completed!" $GREEN
