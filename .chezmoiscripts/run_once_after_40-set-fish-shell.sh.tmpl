#!{{ lookPath "bash" }}
# Ensure shell is changed to fish

set -euo pipefail

# Define colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Function to print a message with a color
print_msg() {
	local msg=$1
	local color=$2
	echo -e "${color}${msg}${NC}"
}

print_msg "Ensure Fish shell ===========================================" $YELLOW

# Set fish as default shell
if ! command -v fish &> /dev/null; then
	print_msg "Fish not installed, skipping shell change" $RED
	exit 0
fi

# Check actual login shell from passwd, not $SHELL env var
current_shell=$(getent passwd "$(whoami)" | cut -d: -f7)
fish_path=$(command -v fish)

if [ "$current_shell" != "$fish_path" ]; then
	print_msg "Changing shell to fish ===========================================" $GREEN
	echo "Changing default shell to fish"

	if chsh -s "$fish_path"; then
		print_msg "Shell changed to fish" $GREEN
	elif sudo chsh -s "$fish_path" "$(whoami)"; then
		print_msg "Shell changed to fish with sudo" $GREEN
	elif sudo usermod --shell "$fish_path" "$(whoami)"; then
		print_msg "Shell changed to fish with usermod" $GREEN
	else
		print_msg "Unable to change shell automatically. Run 'chsh -s $fish_path' manually." $RED
		exit 1
	fi
else
	print_msg "Shell already fish ===========================================" $GREEN
fi
